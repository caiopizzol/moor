{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    ["@semantic-release/npm", { "npmPublish": false }],
    ["@semantic-release/github", { "successComment": false, "releasedLabels": false }],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json"],
        "message": "chore(release): ${nextRelease.version}"
      }
    ]
  ]
}
