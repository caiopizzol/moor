#!/bin/sh
set -e

REPO="caiopizzol/moor"
BRANCH="main"
BASE="https://raw.githubusercontent.com/$REPO/$BRANCH"

WITH_API_KEY=0
for arg in "$@"; do
  case "$arg" in
    --with-api-key) WITH_API_KEY=1 ;;
  esac
done

echo "Installing moor..."

# Check dependencies
if ! command -v docker >/dev/null 2>&1; then
  echo "Error: docker is not installed." >&2
  echo "" >&2
  echo "Install Docker Engine 25.0+ from the official repository:" >&2
  echo "  https://docs.docker.com/engine/install/" >&2
  echo "" >&2
  echo "Required packages: docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin" >&2
  exit 1
fi

if ! docker compose version >/dev/null 2>&1; then
  echo "Error: docker compose v2 plugin is not available." >&2
  echo "Install: https://docs.docker.com/compose/install/" >&2
  exit 1
fi

# Download compose file
curl -fsSL "$BASE/docker-compose.yml" -o docker-compose.yml

touch .env

# Default compose project name to "moor" for predictable container names in
# docker ps output. Moor resolves the actual project from compose labels at
# runtime, so a different value here works too - this is just for naming.
existing=$(grep -E "^COMPOSE_PROJECT_NAME=" .env | head -1 | cut -d= -f2)
if [ -z "$existing" ]; then
  echo "COMPOSE_PROJECT_NAME=moor" >> .env
fi

# Generate a random initial admin password if one isn't already set.
# Moor will use this on first boot to create the admin user. The variable is
# create-only: ignored once an admin exists, so it's safe to leave in .env.
if grep -q "^MOOR_INITIAL_PASSWORD=" .env; then
  INITIAL_PASSWORD=$(grep "^MOOR_INITIAL_PASSWORD=" .env | head -1 | cut -d= -f2-)
  PASSWORD_NOTE="reusing existing MOOR_INITIAL_PASSWORD from .env"
else
  # Read more random bytes than needed so the alphanumeric filter has plenty
  # of input to draw from. 48 bytes → ~64 base64 chars → ~60 after stripping
  # +/=, head -c 24 always succeeds with comfortable margin.
  INITIAL_PASSWORD=$(head -c 48 /dev/urandom | base64 | tr -dc 'A-Za-z0-9' | head -c 24)
  echo "MOOR_INITIAL_PASSWORD=$INITIAL_PASSWORD" >> .env
  PASSWORD_NOTE="generated new MOOR_INITIAL_PASSWORD in .env"
fi

# Optional: generate a MOOR_API_KEY for CLI/MCP/bearer-token access.
# Opt-in via --with-api-key. Grants full admin (Docker socket) access -
# treat the value like SSH access.
API_KEY=""
API_KEY_NOTE=""
if [ "$WITH_API_KEY" = "1" ]; then
  if grep -q "^MOOR_API_KEY=" .env; then
    API_KEY=$(grep "^MOOR_API_KEY=" .env | head -1 | cut -d= -f2-)
    API_KEY_NOTE="reusing existing MOOR_API_KEY from .env"
  else
    API_KEY=$(head -c 80 /dev/urandom | base64 | tr -dc 'A-Za-z0-9' | head -c 40)
    echo "MOOR_API_KEY=$API_KEY" >> .env
    API_KEY_NOTE="generated new MOOR_API_KEY in .env"
  fi
fi

echo ""
echo "Done! Files created/updated:"
echo "  - docker-compose.yml"
echo "  - .env ($PASSWORD_NOTE)"
if [ -n "$API_KEY_NOTE" ]; then
  echo "  - .env ($API_KEY_NOTE)"
fi
echo ""
echo "Initial admin password (also stored in .env):"
echo "  $INITIAL_PASSWORD"
if [ -n "$API_KEY" ]; then
  echo ""
  echo "MOOR_API_KEY (also stored in .env, grants full admin access):"
  echo "  $API_KEY"
  echo "  CLI / MCP setup: https://github.com/caiopizzol/moor#cli"
fi
echo ""
echo "Next steps:"
echo "  1. Run: docker compose up -d"
echo "  2. Open an SSH tunnel from your laptop:"
echo "       ssh -L 8080:127.0.0.1:3000 your-server"
echo "  3. Open http://localhost:8080 and log in with the password above."
echo "  4. Optionally remove MOOR_INITIAL_PASSWORD from .env after first login."
echo ""
if [ -z "$API_KEY" ]; then
  echo "To enable CLI/MCP later, add MOOR_API_KEY=<random> to .env and run"
  echo "docker compose up -d. See the README for details."
  echo ""
fi
echo "The admin UI is bound to 127.0.0.1:3000 by default; Caddy on 80/443"
echo "serves only project domains you add later. See the README for putting"
echo "the admin on a public domain."
