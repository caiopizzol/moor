#!/bin/sh
set -e

REPO="caiopizzol/moor"
BRANCH="main"
BASE="https://raw.githubusercontent.com/$REPO/$BRANCH"

echo "Installing moor..."

# Check dependencies
if ! command -v docker >/dev/null 2>&1; then
  echo "Error: docker is not installed." >&2
  echo "" >&2
  echo "Install Docker Engine 25.0+ from the official repository:" >&2
  echo "  https://docs.docker.com/engine/install/" >&2
  echo "" >&2
  echo "Required packages: docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin" >&2
  exit 1
fi

if ! docker compose version >/dev/null 2>&1; then
  echo "Error: docker compose v2 plugin is not available." >&2
  echo "Install: https://docs.docker.com/compose/install/" >&2
  exit 1
fi

# Download compose file
curl -fsSL "$BASE/docker-compose.yml" -o docker-compose.yml

# Pin the compose project name so moor's hardcoded container/network references resolve.
touch .env
existing=$(grep -E "^COMPOSE_PROJECT_NAME=" .env | head -1 | cut -d= -f2)
if [ -z "$existing" ]; then
  echo "COMPOSE_PROJECT_NAME=moor" >> .env
elif [ "$existing" != "moor" ]; then
  echo "Error: .env already has COMPOSE_PROJECT_NAME=$existing." >&2
  echo "Moor requires COMPOSE_PROJECT_NAME=moor (hardcoded container/network names)." >&2
  echo "Remove or change that line in .env and re-run." >&2
  exit 1
fi

echo ""
echo "Done! Files created/updated:"
echo "  - docker-compose.yml"
echo "  - .env (COMPOSE_PROJECT_NAME=moor)"
echo ""
echo "Next steps:"
echo "  1. Before first boot on a public server, bind Caddy to 127.0.0.1 in"
echo "     docker-compose.yml or restrict ports 80/443 with a cloud firewall."
echo "     The setup-password page is unauthenticated until the password is set,"
echo "     and moor mounts /var/run/docker.sock. See README first-boot security."
echo "  2. Run: docker compose up -d"
echo "  3. Open the admin and set the initial password."
echo ""
echo "Custom domain for the admin UI is configured post-boot. See the README."
