{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "includes": [
      "apps/api/**/*.ts",
      "apps/web/src/**/*.{ts,tsx,css}",
      "apps/web/vite.config.ts",
      "packages/**/*.{ts,tsx}"
    ]
  }
}
